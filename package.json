{
  "name": "gitlab-tui",
  "version": "0.1.0",
  "description": "Terminal UI for GitLab merge request review",
  "type": "module",
  "bin": {
    "gitlab-tui": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "build": "tsup src/index.tsx --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "chalk": "^5.6.2",
    "ink": "^7.0.3",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["gitlab", "tui", "terminal", "cli", "merge-request", "code-review"],
  "license": "MIT"
}
